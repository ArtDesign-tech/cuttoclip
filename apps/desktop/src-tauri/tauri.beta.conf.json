{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CutToClip Beta",
  "version": "0.2.0-beta.1",
  "identifier": "app.cuttoclip.studio.beta",
  "build": {
    "beforeBuildCommand": "npm run build --workspace @cuttoclip/web",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CutToClip Beta",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "category": "Video",
    "shortDescription": "CutToClip Beta for testers",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "Indonesian"]
      }
    }
  }
}
