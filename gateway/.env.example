# Closed-beta production gateway. Copy this file to gateway/.env and fill secrets locally.
NODE_ENV=production
HOST=127.0.0.1
PORT=4327

# Keep this file outside source control and restrict it to the gateway operator.
GATEWAY_DB_PATH=C:\ProgramData\CutToClip\Gateway\gateway.sqlite3
ALLOWED_PUBLIC_HOST=gateway.<your-domain>
TRUST_PROXY_CIDRS=127.0.0.1,::1

# Groq transcription provider.
GROQ_API_KEY=
GROQ_TRANSCRIPTION_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Exact OpenAI-compatible Chat Completions URL for the 9router tunnel.
AI_GATEWAY_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=

# Kept below Cloudflare's default 120-second proxy deadline.
UPSTREAM_TIMEOUT_MS=50000
UPSTREAM_TOTAL_TIMEOUT_MS=110000
UPSTREAM_RETRY_COUNT=1
HIGHLIGHT_CONCURRENCY=2
TRANSCRIPTION_GLOBAL_CONCURRENCY=2
HIGHLIGHT_GLOBAL_CONCURRENCY=2
UPSTREAM_QUEUE_LIMIT=8
UPSTREAM_QUEUE_TIMEOUT_MS=30000
LOG_LEVEL=info
